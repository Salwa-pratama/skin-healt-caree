generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserPublic {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  name                 String
  role                 String                @default("user")
  passwordHash         String
  refreshTokenHash     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  skintype             String                @default("normal")
  acneProblems         AcneProblem[]
  acneProblemSolutions AcneProblemSolution[]
}

model AcneProblem {
  id                   Int                   @id @default(autoincrement())
  citra                String
  name                 String
  userId               Int
  createdAt            DateTime              @default(now())
  predictions          Json?
  user                 UserPublic            @relation(fields: [userId], references: [id])
  acneProblemSolutions AcneProblemSolution[]
}

model AcneSolution {
  id                   Int                   @id @default(autoincrement())
  acneProblemSolutions AcneProblemSolution[]
  BadIngredient        BadIngredient[]
  goodIngredient       GoodIngredient[]      @relation("AcneSolutionToGoodIngredient")
  Habit                Habit[]
  Treatment            Treatment[]
}

model Treatment {
  id           Int            @id @default(autoincrement())
  name         String
  time         String
  AcneSolution AcneSolution[]
}

model Habit {
  id           Int            @id @default(autoincrement())
  name         String
  AcneSolution AcneSolution[]
}

model AcneProblemSolution {
  id             Int          @id @default(autoincrement())
  userId         Int
  acneSolutionId Int
  acneProblemId  Int
  acneProblem    AcneProblem  @relation(fields: [acneProblemId], references: [id])
  acneSolution   AcneSolution @relation(fields: [acneSolutionId], references: [id])
  user           UserPublic   @relation(fields: [userId], references: [id])
}

model GoodIngredient {
  id           Int            @id @default(autoincrement())
  name         String
  acneSolution AcneSolution[] @relation("AcneSolutionToGoodIngredient")
}

model BadIngredient {
  id           Int            @id @default(autoincrement())
  name         String
  AcneSolution AcneSolution[]
}
