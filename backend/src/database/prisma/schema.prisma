generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}


//  ================= User Schema =================
model UserPublic {
    id               Int      @id @default(autoincrement())
    email            String   @unique
    name String
    role             String   @default("user")
    passwordHash     String
    refreshTokenHash String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
    acneProblems AcneProblem[]
}

//  ================= Acne Problem Schema =================
model AcneProblem {
    id Int @id @default(autoincrement())
    citra String
    name String
    // acne_solution_id
    userId Int
    user UserPublic @relation(fields: [userId], references: [id])
}

//  ================= Acne Problem Schema =================
