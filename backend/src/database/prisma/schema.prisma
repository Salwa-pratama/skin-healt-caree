generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model UserPublic {
    id               Int      @id @default(autoincrement())
    email            String   @unique
    name             String
    role             String   @default("user")
    passwordHash     String
    refreshTokenHash String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
}
